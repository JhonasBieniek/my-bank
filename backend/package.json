{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "My Bank API (Node.js)",
  "type": "commonjs",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:seed": "dotenv -e ../.env -- node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3"
  }
}
