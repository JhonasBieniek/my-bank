# ── MySQL (docker-compose) ──────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=my_bank
MYSQL_USER=my_bank
MYSQL_PASSWORD=my_bank
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ── API (fases futuras) ─────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# Connection string para ORM (Prisma, etc.)
DATABASE_URL=mysql://my_bank:my_bank@localhost:3306/my_bank

# ── Frontend (fases futuras) ────────────────────────────────────────────────
FRONTEND_PORT=4200
